{
  "name": "integration-tests-api",
  "version": "1.0.0",
  "main": "index.js",
  "license": "MIT",
  "private": true,
  "scripts": {
    "test:integration": "NODE_OPTIONS=--experimental-vm-modules jest --silent=false --no-cache --maxWorkers=50% --bail --detectOpenHandles --forceExit --logHeapUsage",
    "test:integration:chunk": "NODE_OPTIONS=--experimental-vm-modules jest --silent --no-cache --bail --maxWorkers=50% --forceExit --detectOpenHandles --testPathPattern=$(echo $CHUNKS | jq -r \".[${CHUNK}] | .[]\")",
    "build": "tsc ./src/* --allowJs --outDir ./dist"
  },
  "dependencies": {
    "@8medusa/api-key": "workspace:^",
    "@8medusa/auth": "workspace:*",
    "@8medusa/cache-inmemory": "workspace:*",
    "@8medusa/customer": "workspace:^",
    "@8medusa/event-bus-local": "workspace:*",
    "@8medusa/medusa": "workspace:*",
    "@8medusa/modules-sdk": "workspace:^",
    "@8medusa/payment": "workspace:^",
    "@8medusa/pricing": "workspace:^",
    "@8medusa/product": "workspace:^",
    "@8medusa/promotion": "workspace:^",
    "@8medusa/region": "workspace:^",
    "@8medusa/store": "workspace:^",
    "@8medusa/tax": "workspace:^",
    "@8medusa/user": "workspace:^",
    "@8medusa/utils": "workspace:^",
    "@8medusa/workflow-engine-inmemory": "workspace:*",
    "pg": "^8.11.3"
  },
  "devDependencies": {
    "@swc/core": "^1.4.8",
    "@swc/jest": "^0.2.36",
    "jest": "^29.7.0",
    "typescript": "^5.6.2"
  }
